<UserControl x:Class="InternetShop.WPF.Views.Customer.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="24,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <TextBlock Text="Каталог товаров" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"/>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="24,14"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Margin="0,0,0,0">
            <WrapPanel>
                <TextBox Style="{StaticResource InputBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Width="220" Margin="0,0,10,6">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <ComboBox Style="{StaticResource FilterCombo}"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          DisplayMemberPath="Name"
                          Width="160" Margin="0,0,10,6"/>

                <TextBox Style="{StaticResource InputBox}"
                         Text="{Binding MinPrice, UpdateSourceTrigger=PropertyChanged}"
                         Width="90" Margin="0,0,6,6">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <TextBlock Text="—" VerticalAlignment="Center" Margin="0,0,6,6"
                           Foreground="{StaticResource MutedBrush}"/>
                <TextBox Style="{StaticResource InputBox}"
                         Text="{Binding MaxPrice, UpdateSourceTrigger=PropertyChanged}"
                         Width="90" Margin="0,0,14,6">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <Button Style="{StaticResource PrimaryButton}" Content="Найти"
                        Command="{Binding SearchCommand}"
                        Padding="16,8" Margin="0,0,8,6"/>
                <Button Style="{StaticResource OutlineButton}" Content="Сбросить"
                        Command="{Binding ResetFiltersCommand}"
                        Padding="14,8" Margin="0,0,0,6"/>
            </WrapPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="20,16">
            <Grid>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="0,60"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                 Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Загрузка..." Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusText}"
                           FontSize="16" Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,60"
                           Visibility="{Binding StatusText,
                               Converter={StaticResource StringToVisibility}}"/>

                <ItemsControl ItemsSource="{Binding Products}"
                              Visibility="{Binding IsBusy,
                                  Converter={StaticResource InverseBoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}"
                                    Width="210" Margin="0,0,16,16"
                                    Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.OpenProductCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <Border Background="#F0F7FF" Height="130"
                                            CornerRadius="6" Margin="0,0,0,12">
                                        <TextBlock Text="📦" FontSize="48"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Text="{Binding CategoryName}"
                                               FontSize="11" Foreground="{StaticResource MutedBrush}"
                                               Margin="0,0,0,4"/>

                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               TextWrapping="Wrap" MaxHeight="40"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,8"/>

                                    <DockPanel>
                                        <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}"
                                                   FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}"/>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding Stock, StringFormat={}На складе: {0}}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   VerticalAlignment="Bottom"/>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="3" Background="White" Padding="24,12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" FontSize="13">
                    <Run Text="Товаров: "/>
                    <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                    <Run Text=" · Страница "/>
                    <Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                    <Run Text=" из "/>
                    <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                </TextBlock>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource OutlineButton}" Content="← Назад"
                            Command="{Binding PrevPageCommand}"
                            IsEnabled="{Binding HasPrev}"
                            Padding="14,7" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource OutlineButton}" Content="Вперёд →"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding HasNext}"
                            Padding="14,7"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
