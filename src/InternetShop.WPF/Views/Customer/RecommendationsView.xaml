<UserControl x:Class="InternetShop.WPF.Views.Customer.RecommendationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="24,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="⭐ Рекомендации для вас"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Подобрано на основе ваших покупок и просмотров"
                           FontSize="13" Foreground="{StaticResource MutedBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <Grid>
                <StackPanel HorizontalAlignment="Center" Margin="0,60"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                 Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Загрузка рекомендаций..."
                               Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" Margin="0,80"
                            Visibility="{Binding StatusText,
                                Converter={StaticResource StringToVisibility}}">
                    <TextBlock Text="⭐" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="16" Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Items}"
                              Visibility="{Binding IsBusy,
                                  Converter={StaticResource InverseBoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}"
                                    Width="210" Margin="0,0,16,16" Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.OpenProductCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <Border Background="#FFF8E1" Height="130"
                                            CornerRadius="6" Margin="0,0,0,12">
                                        <TextBlock Text="⭐" FontSize="48"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding CategoryName}"
                                               FontSize="11" Foreground="{StaticResource MutedBrush}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14" FontWeight="SemiBold"
                                               TextWrapping="Wrap" MaxHeight="40"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
