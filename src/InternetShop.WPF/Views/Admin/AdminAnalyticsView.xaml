<UserControl x:Class="InternetShop.WPF.Views.Admin.AdminAnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="24,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="📊 Аналитика" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Style="{StaticResource OutlineButton}"
                        Content="↻ Обновить" Command="{Binding RefreshCommand}"
                        Padding="14,7" Width="201"/>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16,20,20">

                <StackPanel HorizontalAlignment="Center" Margin="0,60"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                 Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Загрузка данных..." Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <StackPanel Visibility="{Binding IsBusy,
                                Converter={StaticResource InverseBoolToVisibility}}">

                    <UniformGrid Columns="3" Margin="0,0,0,20">
                        <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Общая выручка" FontSize="13"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding TotalRevenue, StringFormat={}{0:N0} ₽}"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text="за всё время" FontSize="12"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="5,0">
                            <StackPanel>
                                <TextBlock Text="Заказов" FontSize="13"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding TotalOrders}"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="выполнено" FontSize="12"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="10,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Покупателей" FontSize="13"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding TotalUsers}"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="зарегистрировано" FontSize="12"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Динамика выручки" FontSize="15" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                                <lvc:CartesianChart
                                    Series="{Binding SalesSeries}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}"
                                    Height="260"
                                    LegendPosition="Hidden"
                                    TooltipPosition="Top"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Топ-5 товаров" FontSize="15" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                                <lvc:PieChart
                                    Series="{Binding PieSeries}"
                                    Height="220"
                                    LegendPosition="Bottom"
                                    InitialRotation="-90"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding TopProducts.Count,
                                Converter={StaticResource PositiveToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="Топ товаров по продажам" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                            <DataGrid ItemsSource="{Binding TopProducts}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      GridLinesVisibility="None"
                                      HeadersVisibility="Column"
                                      BorderThickness="0"
                                      FontSize="13"
                                      RowBackground="White"
                                      AlternatingRowBackground="#FAFBFC">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                        <Setter Property="MinHeight"                Value="48"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="BorderBrush"              Value="{StaticResource BorderBrush}"/>
                                        <Setter Property="BorderThickness"          Value="0,0,0,1"/>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background"   Value="#F4F6F8"/>
                                        <Setter Property="Foreground"   Value="{StaticResource MutedBrush}"/>
                                        <Setter Property="FontWeight"   Value="SemiBold"/>
                                        <Setter Property="FontSize"     Value="12"/>
                                        <Setter Property="Padding"      Value="14,8"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding"          Value="14,0"/>
                                        <Setter Property="BorderThickness"  Value="0"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridCell">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderThickness="0"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Товар"
                                                        Binding="{Binding ProductName}" Width="*"/>
                                    <DataGridTextColumn Header="Продано (шт.)"
                                                        Binding="{Binding SoldCount}"   Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
