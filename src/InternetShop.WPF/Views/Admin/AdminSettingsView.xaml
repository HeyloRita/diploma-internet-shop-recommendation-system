<UserControl x:Class="InternetShop.WPF.Views.Admin.AdminSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="24,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <TextBlock Text="⚙️ Настройки управления" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel MaxWidth="520" HorizontalAlignment="Left">

                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,0,0,20"
                             Foreground="{StaticResource PrimaryBrush}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

                <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Параметры системы" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

                        <TextBlock Text="Порог дозаказа (шт.)" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}"
                                   Margin="0,0,0,8" TextWrapping="Wrap">
                            Задания на дозаказ создаются, когда остаток товара падает
                            до этого значения или ниже.
                        </TextBlock>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding LowStockThreshold, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,20" Width="120" HorizontalAlignment="Left"/>

                        <TextBlock Text="Количество рекомендаций для пользователя"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}"
                                   Margin="0,0,0,8" TextWrapping="Wrap">
                            Сколько персонализированных товаров показывать каждому пользователю.
                        </TextBlock>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding RecommendationCount, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,24" Width="120" HorizontalAlignment="Left"/>

                        <Button Style="{StaticResource PrimaryButton}" Content="Сохранить настройки"
                                Command="{Binding SaveCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                HorizontalAlignment="Left" Padding="20,10"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Рекомендательная модель" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                        <TextBlock FontSize="13" Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,20" LineHeight="20">
                            Модель автоматически переобучается раз в 24 часа.
                            Нажмите кнопку для немедленного запуска переобучения
                            на текущих данных о поведении пользователей.
                        </TextBlock>
                        <Button Style="{StaticResource OutlineButton}"
                                Content="🔄 Переобучить модель сейчас"
                                Command="{Binding RetrainCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                HorizontalAlignment="Left" Padding="16,9"/>
                    </StackPanel>
                </Border>

                <Border CornerRadius="8" Padding="14,10"
                        Visibility="{Binding StatusMessage,
                            Converter={StaticResource StringToVisibility}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                    <Setter Property="Background" Value="#E8F5E9"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                    <Setter Property="Background" Value="#FFEBEE"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                        <Setter Property="Foreground" Value="#C62828"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
