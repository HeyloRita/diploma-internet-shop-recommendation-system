<UserControl x:Class="InternetShop.WPF.Views.Admin.AdminProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="24,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="🏪 Управление товарами" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                        Content="＋ Добавить товар" Command="{Binding StartAddCommand}"
                        Padding="18,8"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">

            <Border Margin="20,16,20,20" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                     Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding Products}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserSortColumns="True"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              RowBackground="White"
                              AlternatingRowBackground="#FAFBFC"
                              BorderThickness="0"
                              FontSize="13"
                              Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisibility}}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"      Value="#F4F6F8"/>
                                <Setter Property="Foreground"      Value="{StaticResource MutedBrush}"/>
                                <Setter Property="FontWeight"      Value="SemiBold"/>
                                <Setter Property="FontSize"        Value="12"/>
                                <Setter Property="Padding"         Value="12,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding"           Value="12,6"/>
                                <Setter Property="BorderThickness"   Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderThickness="0"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                        <Setter Property="Padding"      Value="0,4"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                        <Setter Property="Padding"      Value="0,4"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Цена"
                                                Binding="{Binding Price, StringFormat={}{0:N0} ₽}"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                        <Setter Property="Padding"      Value="0,4"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Остаток"
                                                Binding="{Binding Stock}"
                                                Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                        <Setter Property="Padding"      Value="0,4"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Статус" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="6,2" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Background" Value="#FFEBEE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"        Value="Активен"/>
                                                        <Setter Property="Foreground"  Value="#2E7D32"/>
                                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                                        <Setter Property="Padding"      Value="0,4"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Text"       Value="Скрыт"/>
                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="✏ Изменить"
                                                    Style="{StaticResource OutlineButton}"
                                                    Padding="8,4" FontSize="12"
                                                    Command="{Binding DataContext.StartEditCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="🗑"
                                                    Style="{StaticResource OutlineButton}"
                                                    Padding="8,4" FontSize="12" Margin="6,0,0,0"
                                                    Foreground="{StaticResource AccentBrush}"
                                                    BorderBrush="{StaticResource AccentBrush}"
                                                    Command="{Binding DataContext.DeleteCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding IsActive,
                                                        Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Width="590" HorizontalAlignment="Center"
                    Margin="0,16,20,20"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.12" Direction="270"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20">

                        <DockPanel Margin="0,0,0,16">
                            <TextBlock Text="{Binding FormTitle}"
                                       FontSize="17" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right"
                                    Content="✕" FontSize="16"
                                    Foreground="{StaticResource MutedBrush}"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="4"
                                    Command="{Binding CancelCommand}"/>
                        </DockPanel>

                        <TextBlock Text="Название *" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Описание" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Height="72" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Цена (₽) *" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource InputBox}"
                                         Text="{Binding EditPrice, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Остаток *" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource InputBox}"
                                         Text="{Binding EditStock, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Категория *" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <ComboBox Style="{StaticResource FilterCombo}"
                                  ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding EditCategory}"
                                  DisplayMemberPath="Name"
                                  Margin="0,0,0,12"/>

                        <TextBlock Text="Ссылка на изображение" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="{Binding EditImageUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <CheckBox Content="Товар активен (виден покупателям)"
                                  IsChecked="{Binding EditIsActive}"
                                  FontSize="13" Foreground="{StaticResource TextBrush}"
                                  Margin="0,0,0,16"
                                  Visibility="{Binding IsNew,
                                      Converter={StaticResource InverseBoolToVisibility}}"/>

                        <Border CornerRadius="4" Padding="10,6" Margin="0,0,0,12"
                                Visibility="{Binding StatusMessage,
                                    Converter={StaticResource StringToVisibility}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFEBEE"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding StatusMessage}" FontSize="13" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#C62828"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Style="{StaticResource PrimaryButton}"
                                    Content="💾 Сохранить"
                                    Command="{Binding SaveCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                    Padding="0,10"/>
                            <Button Grid.Column="2"
                                    Style="{StaticResource OutlineButton}"
                                    Content="Отмена"
                                    Command="{Binding CancelCommand}"
                                    Padding="16,10"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>
    </Grid>
</UserControl>
