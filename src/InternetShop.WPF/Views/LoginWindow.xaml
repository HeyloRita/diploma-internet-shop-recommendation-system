<Window x:Class="InternetShop.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Интернет-магазин — Вход"
        Height="650" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">

    <Border Margin="32" CornerRadius="12" Background="White"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.08" Direction="270"/>
        </Border.Effect>

        <StackPanel Margin="36,32">
            <TextBlock Text="🛒 Магазин" FontSize="26" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock x:Name="SubTitle"
                       Text="{Binding ShowRegister, Converter={StaticResource BoolToHeader}}"
                       FontSize="14" Foreground="{StaticResource MutedBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,28"/>

            <StackPanel Visibility="{Binding ShowRegister,
                            Converter={StaticResource InverseBoolToVisibility}}">
                <TextBlock Text="E-mail" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource InputBox}"
                         Text="{Binding LoginEmail, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,14"/>

                <TextBlock Text="Пароль" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="LoginPwd" Style="{StaticResource InputPassword}"
                             Margin="0,0,0,24"/>

                <Button Style="{StaticResource PrimaryButton}" Content="Войти"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Click="OnLoginClick"/>
            </StackPanel>

            <StackPanel Visibility="{Binding ShowRegister,
                            Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="Имя" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource InputBox}"
                         Text="{Binding RegName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,14"/>

                <TextBlock Text="E-mail" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource InputBox}"
                         Text="{Binding RegEmail, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,14"/>

                <TextBlock Text="Пароль" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="RegPwd" Style="{StaticResource InputPassword}"
                             Margin="0,0,0,24"/>

                <Button Style="{StaticResource PrimaryButton}" Content="Зарегистрироваться"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                        Click="OnRegisterClick"/>
            </StackPanel>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource AccentBrush}"
                       FontSize="13" TextWrapping="Wrap"
                       HorizontalAlignment="Center" Margin="0,12,0,0"
                       Visibility="{Binding ErrorMessage,
                           Converter={StaticResource StringToVisibility}}"/>

            <ProgressBar IsIndeterminate="True" Height="3" Margin="0,10,0,0"
                         Foreground="{StaticResource PrimaryBrush}"
                         Visibility="{Binding IsBusy,
                             Converter={StaticResource BoolToVisibility}}"/>

            <Button Style="{StaticResource OutlineButton}"
                    Command="{Binding ToggleFormCommand}"
                    HorizontalAlignment="Center" Margin="0,20,0,0">
                <TextBlock>
                    <Run Text="{Binding ShowRegister,
                             Converter={StaticResource BoolToToggleText}}"/>
                </TextBlock>
            </Button>
        </StackPanel>
    </Border>
</Window>
