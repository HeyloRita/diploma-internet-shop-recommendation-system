<UserControl x:Class="InternetShop.WPF.Views.Admin.AdminRecommendationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="24,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="🤖 Модель рекомендаций" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Style="{StaticResource OutlineButton}"
                        Content="↻ Обновить" Command="{Binding RefreshCommand}"
                        Padding="14,7"/>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,24">

                <StackPanel HorizontalAlignment="Center" Margin="0,60"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                 Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="Загрузка данных модели..." Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <Border Background="#FFEBEE" CornerRadius="8" Padding="16,12" Margin="0,0,0,20"
                        Visibility="{Binding StatusText, Converter={StaticResource StringToVisibility}}">
                    <TextBlock Text="{Binding StatusText}" Foreground="#C62828" FontSize="13"/>
                </Border>

                <StackPanel Visibility="{Binding IsBusy,
                                Converter={StaticResource InverseBoolToVisibility}}">

                    <UniformGrid Columns="4" Margin="0,0,0,20">

                        <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Последнее обучение" FontSize="12"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding LastTrainedAt}" FontSize="14"
                                           FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="5,0">
                            <StackPanel>
                                <TextBlock Text="Всего рекомендаций" FontSize="12"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding TotalRecs}" FontSize="26"
                                           FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="5,0">
                            <StackPanel>
                                <TextBlock Text="Пользователей охвачено" FontSize="12"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding UsersWithRecs}" FontSize="26"
                                           FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="10,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Событий для обучения" FontSize="12"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding TrainingEvents}" FontSize="26"
                                           FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Параметры модели" FontSize="15" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Алгоритм" FontSize="13"
                                               Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="#EEF4FF" CornerRadius="4" Padding="10,5">
                                        <TextBlock Text="{Binding Algorithm}" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                                    </Border>
                                </Grid>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Итерации обучения" FontSize="13"
                                               Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ModelIterations}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource TextBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Ранг аппроксимации" FontSize="13"
                                               Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ModelRank}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource TextBrush}"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Библиотека" FontSize="13"
                                               Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="#F3F4F6" CornerRadius="4" Padding="10,5">
                                        <TextBlock Text="ML.NET 3.x" FontSize="13"
                                                   Foreground="{StaticResource TextBrush}"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Топ-5 рекомендуемых товаров" FontSize="15" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                                <DataGrid ItemsSource="{Binding TopRecommended}"
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          GridLinesVisibility="None"
                                          HeadersVisibility="Column"
                                          BorderThickness="0" FontSize="13"
                                          RowBackground="White"
                                          AlternatingRowBackground="#FAFBFC">
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                            <Setter Property="MinHeight"                Value="48"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="BorderBrush"              Value="{StaticResource BorderBrush}"/>
                                            <Setter Property="BorderThickness"          Value="0,0,0,1"/>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background"      Value="#F4F6F8"/>
                                            <Setter Property="Foreground"      Value="{StaticResource MutedBrush}"/>
                                            <Setter Property="FontWeight"      Value="SemiBold"/>
                                            <Setter Property="FontSize"        Value="12"/>
                                            <Setter Property="Padding"         Value="12,8"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding"          Value="12,0"/>
                                            <Setter Property="BorderThickness"  Value="0"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderThickness="0"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Товар"
                                                            Binding="{Binding ProductName}" Width="*"/>
                                        <DataGridTextColumn Header="Рекомендован (раз)"
                                                            Binding="{Binding TimesRecommended}" Width="140"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Управление обучением" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,10"/>
                            <TextBlock FontSize="13" Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="20">
                                Модель автоматически переобучается каждые 24 часа на основе событий
                                просмотров и покупок пользователей (вес покупки = 2, просмотра = 1).
                                Нажмите кнопку для немедленного запуска.
                            </TextBlock>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource PrimaryButton}"
                                        Content="🔄 Переобучить сейчас"
                                        Command="{Binding RetrainCommand}"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                        Padding="18,10"/>
                            </StackPanel>

                            <Border CornerRadius="8" Padding="14,10" Margin="0,16,0,0"
                                    Visibility="{Binding RetrainStatus,
                                        Converter={StaticResource StringToVisibility}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RetrainSuccess}" Value="True">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RetrainSuccess}" Value="False">
                                                <Setter Property="Background" Value="#FFEBEE"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding RetrainStatus}" FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RetrainSuccess}" Value="True">
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RetrainSuccess}" Value="False">
                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
